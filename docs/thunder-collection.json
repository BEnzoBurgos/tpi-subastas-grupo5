      "containerId": "f-auth",
      "url": "{{baseUrl}}/api/auth/register",
      "method": "POST",
      "sortNum": 1,
      "name": "Register",
      "body": {
        "type": "json",
        "raw": "{\n  \"nombre\": \"Juan\",\n  \"apellido\": \"Perez\",\n  \"email\": \"juan@mail.com\",\n  \"password\": \"123456\",\n  \"fechaNacimiento\": \"2000-01-15\"\n}"
      },
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "params": []
    },

    {
      "_id": "r-auth-login",
      "containerId": "f-auth",
      "url": "{{baseUrl}}/api/auth/login",
      "method": "POST",
      "sortNum": 2,
      "name": "Login",
      "body": {
        "type": "json",
        "raw": "{\n  \"email\": \"juan@mail.com\",\n  \"password\": \"123456\"\n}"
      },
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "params": []
